{
  "name": "frameverse-client",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://frameverse.ru/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/machnevegor/frameverse.git",
    "directory": "packages/client"
  },
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build && tsc --noEmit",
    "dev": "dotenvx run --convention=flow -- vite",
    "fmt": "run-s fmt:b fmt:p",
    "fmt:b": "biome check --write --unsafe",
    "fmt:p": "prettier \"**/*.{md,yaml,yml}\" --write --list-different",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "lint": "biome lint .",
    "preview": "dotenvx run --convention=flow -- vite preview"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm audit && pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource-variable/roboto": "^5.2.10",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-table-devtools": "^8.21.3",
    "@tanstack/router-plugin": "^1.166.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@dotenvx/dotenvx": "^1.55.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "shadcn": "^4.0.7",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
